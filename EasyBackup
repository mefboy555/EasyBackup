#!/bin/bash


echo

read -p "Введите путь к папке/файлу для архивации (оставьте пустым для бэкапа всей системы): " SOURCE



if [ -z "$SOURCE" ]; then
    SOURCE="." #Точка означает текущую директорию (все файлы и папки в ней)
    echo "Путь не указан. Архивации подлежит всё текущее содержимое."
fi

if [ ! -e "$SOURCE" ]; then
    echo "Ошибка: Путь '$SOURCE' не существует!"
    exit 1
fi

ARCHIVE_NAME="backup_$(date +%Y%m%d_%H%M%S).tar.gz"


read -p "===== Вы уверены (y/n)?: =====" response

case "$response" in
    [Yy]* ) 
        echo "Вы выбрали ДА. Выполняю действие..."
        echo "Создаю архив $ARCHIVE_NAME..."
		tar -czvf "$ARCHIVE_NAME" "$SOURCE"
		echo "Успешно! Архив создан и сохранен в директорию запуска скрипта"
        ;;
        
    [Nn]* ) 
        echo "Вы выбрали НЕТ. Отмена операции."
        ;;
        
    * ) 
        echo "Неверный ввод. Пожалуйста, выберите y или n."
        ;;
        
esac
